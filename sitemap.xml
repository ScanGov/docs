        wrap.className = 'heading-anchor-text';
        wrap.href = '#' + h.id;
        while (h.firstChild) { wrap.appendChild(h.firstChild); }
        h.appendChild(wrap);
        var icon = document.createElement('a');
        icon.id = 'heading-hashtag';
